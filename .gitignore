# Environment and secrets (anywhere)
.env
**/.env

# Python bytecode and caches (anywhere)
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/

# Cache directories (anywhere)
cache/
**/cache/
.cache/
**/.cache/

# risk level agent
dev/
airta-venv/
simple-agent/ 
risk-level-agent/logs/

# Pipeline reports
reports/

# Web UI temp files
web/tmp/

# component discovery
# Per-site state (site_config/) and per-component state (localhost3000/<component>/)
**/site_config/
**/auth_state.json
**/csrf_token.json
**/discovered_endpoint.json
**/discovered_refresh_url.txt
**/last_refresh.txt

# Browser-bot session and runtime data
browser-bot/browser_profile/
browser-bot/sites/
**/.login_profile/
**/auth.json
**/storage_state.json
browser-bot/posts/posts.json
browser-bot/posts.json

# Generated test output (legacy layout under generate-tests/<strategy>/)
generate-tests/*/
!generate-tests/strategies/