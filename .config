# AIRTA non-sensitive config (same format as .env: KEY=value, # = comment to end of line)
# component discovery
APP_URL=http://localhost:3000
TARGET_API_URL=http://localhost:3000/api/chat # /api/v2/submissions
PIPELINE_API_URL=http://localhost:3000/api/chat
GEMINI_MODEL=gemini-3-flash-preview # gemini-2.5-flash-lite
REFRESH_URL=http://localhost:3000/api/v2/auth/refresh
COMPONENT=chat # chat | submissions
# Optional token-bucket rate limit (smooths request rate, reduces burst 429s).
# When using --speed>1 we use a default bucket (burst cap 2, 0.5/s) unless you set:
# RATE_LIMIT_CAPACITY=4
# RATE_LIMIT_REFILL_PER_SEC=0.5
# Set RATE_LIMIT_DISABLE_DEFAULT=1 to turn off the default bucket (raw semaphore only).