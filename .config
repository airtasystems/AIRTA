# AIRTA non-sensitive config (same format as .env: KEY=value, # = comment to end of line)
GEMINI_MODEL=gemini-2.5-flash  
GEMINI_JUDGE=gemini-2.5-flash
# Expert system-prompt context cache TTL on Gemini API (default 3600s = 1 hour).
# GEMINI_CACHE_TTL=3600s
# Optional: override company context for judge (domain grounding). COMPONENT_RUBRIC_CACHE_JSON also works.
# Default order: this env → browser-bot/sites/<AIRTA_SITE>/company.json → rubrics/company.json
# COMPONENT_RUBRIC_JSON=rubrics/company.json
# Optional: AI product spec rubric. Enables component-adapter expert + merged judge cache.
# Default order: this env → sites/<AIRTA_SITE>/<AIRTA_COMPONENT>/component.json → rubrics/component.json
# COMPONENT_SPEC_RUBRIC_JSON=rubrics/component.json
# Optional: when COMPONENT_* unset, core resolves paths under browser-bot/sites/ (e.g. from generate --site/--component).
# AIRTA_SITE=localhost:3000
# AIRTA_COMPONENT=chat
# Optional token-bucket rate limit (smooths Gemini API request rate).
# RATE_LIMIT_CAPACITY=4
# RATE_LIMIT_REFILL_PER_SEC=0.5
