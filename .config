# AIRTA non-sensitive config (same format as .env: KEY=value, # = comment to end of line)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_JUDGE=gemini-2.5-flash
# Expert system-prompt context cache TTL on Gemini API (default 3600s = 1 hour).
# GEMINI_CACHE_TTL=3600s
# Optional: override default rubrics/company.json for judge (domain context). COMPONENT_RUBRIC_CACHE_JSON also works.
# COMPONENT_RUBRIC_JSON=rubrics/company.json
# Optional: AI product spec rubric (default rubrics/component.json). Enables component-adapter expert + merged judge cache.
# COMPONENT_SPEC_RUBRIC_JSON=rubrics/component.json
# Optional token-bucket rate limit (smooths Gemini API request rate).
# RATE_LIMIT_CAPACITY=4
# RATE_LIMIT_REFILL_PER_SEC=0.5
